    "Bash(sed*)",
    "Bash(grep*)",
    "Bash(cd*)",
    "Bash(cat*)",
    "Bash(ls*)",
    "Bash(mkdir*)",
    "Bash(cp*)",
    "Bash(mv*)"
  ]
}
