# Google OAuth (user login — can reuse same app as Gmail/Drive)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Database
DATABASE_URL=postgresql://localhost:5432/giltee_ledger

# App
