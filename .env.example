# Gmail + Drive (single OAuth app, dual scope)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token_scoped_to_custom_at_giltee
GMAIL_TARGET_ACCOUNT=custom@giltee.com
