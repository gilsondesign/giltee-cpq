{
  "name": "giltee-ledger",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "nodemon server/index.js",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "start": "node server/index.js",
    "test:server": "jest --passWithNoTests",
    "test:client": "vitest run",
    "test": "npm run test:server && npm run test:client"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "connect-pg-simple": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfmake": "^0.2.9",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "jsdom": "^23.0.1",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.31",
    "supertest": "^6.3.3",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/__tests__/**/*.test.js", "**/server/routes/__tests__/**/*.test.js"],
    "testPathIgnorePatterns": ["/node_modules/"],
    "setupFiles": ["<rootDir>/server/__tests__/jest.env.setup.js"]
  }
}
